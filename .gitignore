.DS_Store
__pycache__/
*.pyc

# pygbag build artifacts and cache - regenerated by `python3 -m pygbag --build main.py`
build/

# local leaderboard database - each environment has its own
leaderboard.db

# captured-territory background photos: the ones already committed stay
# tracked, but new ones dropped in here (see README - "Replacing background
# photos") aren't picked up by git, so rotating them doesn't touch the repo
pics/backgrounds/*

# per-environment config overrides (e.g. production LEADERBOARD_BASE_URL) -
# see local_settings.example.py
local_settings.py

# editor/tooling
.vscode/
.claude/
