# This block needs to be ADDED to the existing system /etc/caddy/Caddyfile
# on the server (not run as a separate container - there's already a Caddy
# there holding ports 80/443). After adding it: systemctl reload caddy
#
# The `root` path below assumes the repo was cloned into /opt/sha - adjust
# it if you cloned it somewhere else.

games.glamkit.ai {
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy 127.0.0.1:8765
	}
	handle {
		root * /opt/sha/build/web
		file_server
	}
}
